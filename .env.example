# -------------------------------------------------------------------
# Project
# -------------------------------------------------------------------
COMPOSE_PROJECT_NAME=market_streaming_data_platform
ENVIRONMENT=local

# -------------------------------------------------------------------
# Market data source
# -------------------------------------------------------------------
MARKET_EXCHANGE=binance
MARKET_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# -------------------------------------------------------------------
# Kafka
# -------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_EXTERNAL_PORT=9092

KAFKA_TOPIC_TRADES_RAW=market.trades.raw
KAFKA_TOPIC_TRADES_CLEANED=market.trades.cleaned
KAFKA_TOPIC_CANDLES_1M=market.candles.1m

# -------------------------------------------------------------------
# Iceberg REST Catalog
# -------------------------------------------------------------------
ICEBERG_REST_URI=http://iceberg-rest:8181
ICEBERG_REST_HOST_URI=http://localhost:8181
ICEBERG_REST_PORT=8181
ICEBERG_CATALOG_NAME=market_catalog
ICEBERG_WAREHOUSE=s3://market-lake/warehouse
ICEBERG_BRONZE_TABLE=market_catalog.market.bronze_trades

# -------------------------------------------------------------------
# Local S3-compatible object storage
# -------------------------------------------------------------------
S3_ENDPOINT=http://minio:9000
S3_HOST_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1

# Local S3 client credentials must match the local MinIO root credentials below.
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PATH_STYLE_ACCESS=true
S3A_SSL_ENABLED=false

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=market-lake

# -------------------------------------------------------------------
# ClickHouse
# -------------------------------------------------------------------
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_NATIVE_HOST_PORT=9002

CLICKHOUSE_DATABASE=market_data
CLICKHOUSE_USER=market_user
CLICKHOUSE_PASSWORD=market_password

# -------------------------------------------------------------------
# Spark
# -------------------------------------------------------------------
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_MASTER_UI_PORT=8080
SPARK_WORKER_UI_PORT=8081

SPARK_CHECKPOINT_LOCATION=s3a://market-lake/checkpoints

ICEBERG_TRADE_CHECKPOINT_LOCATION=s3a://market-lake/checkpoints/market/bronze-trades
ICEBERG_TRADE_QUERY_NAME=market-iceberg-bronze-trades
ICEBERG_TRADE_APP_NAME=market-iceberg-trade-streaming
ICEBERG_TRADE_PROCESSING_TIME=
